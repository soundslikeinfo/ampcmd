#!/bin/sh
# ampcmd - Universal wrapper that detects shell and calls appropriate implementation
# Usage: ampcmd [N] or ampcmd -l

set -e

# Resolve symlinks to find the real script location.
# Homebrew installs a symlink at /opt/homebrew/bin/ampcmd -> Cellar/ampcmd/VERSION/bin/ampcmd
# Using $0 directly gives the symlink path, so ../libexec resolves to /opt/homebrew/libexec
# instead of the Cellar versioned directory. We must follow symlinks first.
# macOS does not have readlink -f, so we use a POSIX-compatible loop.
WRAPPER_PATH="$0"
while [ -L "$WRAPPER_PATH" ]; do
    _dir="$(cd "$(dirname "$WRAPPER_PATH")" && pwd)"
    WRAPPER_PATH="$(readlink "$WRAPPER_PATH")"
    case "$WRAPPER_PATH" in
        /*) ;;
        *) WRAPPER_PATH="$_dir/$WRAPPER_PATH" ;;
    esac
done
WRAPPER_DIR="$(cd "$(dirname "$WRAPPER_PATH")" && pwd)"

# Try Homebrew Cellar structure first (wrapper is symlink or in Cellar)
if [ -f "$WRAPPER_DIR/../libexec/ampcmd.zsh" ]; then
    SCRIPT_DIR="$(cd "$WRAPPER_DIR/../libexec" && pwd)"
# Try manual install structure
elif [ -f "$WRAPPER_DIR/../share/ampcmd/libexec/ampcmd.zsh" ]; then
    SCRIPT_DIR="$(cd "$WRAPPER_DIR/../share/ampcmd/libexec" && pwd)"
else
    echo "ampcmd: Cannot find libexec directory" >&2
    echo "Expected one of:" >&2
    echo "  $WRAPPER_DIR/../libexec/ampcmd.zsh" >&2
    echo "  $WRAPPER_DIR/../share/ampcmd/libexec/ampcmd.zsh" >&2
    exit 1
fi

# Detect current shell
DETECTED_SHELL="${SHELL##*/}"

# Fallback to zsh if can't detect
: "${DETECTED_SHELL:=zsh}"

# Execute the appropriate shell version
# Pass all arguments properly quoted
case "$DETECTED_SHELL" in
*zsh*)
	exec env _ampcmd_plugin_dir="$SCRIPT_DIR" zsh -c \
		'source "$_ampcmd_plugin_dir/ampcmd.zsh" && ampcmd "$@"' zsh "$@"
	;;
*bash*)
	exec env _ampcmd_plugin_dir="$SCRIPT_DIR" bash -c \
		'source "$_ampcmd_plugin_dir/ampcmd.bash" && ampcmd "$@"' bash "$@"
	;;
*fish*)
	exec fish -c "source '$SCRIPT_DIR/ampcmd.fish'; and ampcmd \$argv" -- "$@"
	;;
*)
	echo "ampcmd: Unsupported shell: $DETECTED_SHELL" >&2
	echo "Supported shells: zsh, bash, fish" >&2
	exit 1
	;;
esac
